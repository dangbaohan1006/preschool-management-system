# 🌍 THÀNH DANH PRESCHOOL SYSTEM CONFIGURATION TEMPLATE
# Copy file này thành .env để cấu hình local nếu cần (không commit .env lên Git)

# --- Backend Configuration (Cloudflare Worker) ---
# Mã bí mật bảo vệ API kết nối nội bộ
API_KEY=SECRET_INTERNAL_KEY_2026

# --- Frontend Configuration ---
# API endpoint base URL (Tự động nhận diện local/production)
# Local: http://127.0.0.1:8787/api
# Production: https://preschool-edge-api.diemdanh-tds.workers.dev/api

# --- Local ETL Sync Engine Configuration ---
# Google Sheets ID để đồng bộ điểm danh
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Đường dẫn lưu file key dịch vụ Google Cloud Service Account
GOOGLE_APPLICATION_CREDENTIALS=local-etl-engine/credentials/gcp_service_account.json
